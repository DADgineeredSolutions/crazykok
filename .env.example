# Runtime mode. Keep the committed default non-production.
APP_ENV=development

# Public virtual hosts served by the Docker web gateway.
# For cloud hosting, override with crazykok.com/app.crazykok.com/api.crazykok.com.
APP_DOMAIN=crazykok.local
APP_DOMAIN_ALIAS=app.crazykok.local
API_DOMAIN=api.crazykok.local

# Comma-separated browser origins allowed to call the API directly.
CORS_ALLOWED_ORIGINS=https://crazykok.local,https://app.crazykok.local

# Host ports used by Docker Compose. Port 80 redirects to HTTPS.
WEB_PORT=80
HTTPS_PORT=443
API_PORT=8000

# The local SQLite database is stored in the api-data Docker volume.
DATABASE_URL=sqlite:////data/app.db
