# Runtime mode. Keep the committed default non-production.
APP_ENV=development

# Public virtual hosts served by the Docker web gateway.
# For cloud hosting, override with crazykok.com/app.crazykok.com/api.crazykok.com.
APP_DOMAIN=crazykok.local
APP_DOMAIN_ALIAS=app.crazykok.local
API_DOMAIN=api.crazykok.local
DOCS_DOMAIN=docs.crazykok.local
API_DOCS_DOMAIN=api-docs.crazykok.local
DB_DOMAIN=db.crazykok.local
AUTH_DOMAIN=auth.crazykok.local
IDP_STUB_DOMAIN=idp.crazykok.local

# Authentication service. The default starts authentik but leaves gateway
# enforcement disabled until an authentik proxy provider/outpost is configured.
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server:latest
AUTHENTIK_SECRET_KEY=change-me-generate-a-long-random-secret
AUTH_POSTGRES_DB=authentik
AUTH_POSTGRES_USER=authentik
AUTH_POSTGRES_PASSWORD=change-me-authentik-postgres
AUTHENTIK_ERROR_REPORTING_ENABLED=false
AUTHENTIK_EMAIL_HOST=
AUTHENTIK_EMAIL_PORT=587
AUTHENTIK_EMAIL_USERNAME=
AUTHENTIK_EMAIL_PASSWORD=
AUTHENTIK_EMAIL_USE_TLS=true
AUTHENTIK_EMAIL_FROM=auth@crazykok.local
AUTHENTIK_BOOTSTRAP_EMAIL=
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_BOOTSTRAP_TOKEN=

# Google federation. Values are supplied by a Google Cloud OAuth web client;
# do not commit the client secret. Google requires a real HTTPS public domain,
# so these are intentionally separate from the .local development defaults.
AUTHENTIK_GOOGLE_CLIENT_ID=
AUTHENTIK_GOOGLE_CLIENT_SECRET=
AUTHENTIK_GOOGLE_ALLOWED_DOMAIN=
AUTHENTIK_PUBLIC_URL=https://auth.crazykok.com
AUTHENTIK_APP_PUBLIC_URL=https://crazykok.com
AUTHENTIK_PORTAL_LOGOUT_URL=https://crazykok.com/logout
AUTHENTIK_DB_PUBLIC_URL=https://db.crazykok.com

# Disposable local OIDC upstream used to exercise authentik federation.
IDP_STUB_IMAGE=quay.io/keycloak/keycloak:26.7.0
IDP_STUB_ADMIN_USERNAME=admin
IDP_STUB_ADMIN_PASSWORD=local-idp-admin
FULL_LOGOUT_URL=https://idp.crazykok.local/realms/crazykok-local/protocol/openid-connect/logout?client_id=authentik-local&post_logout_redirect_uri=https%3A%2F%2Fcrazykok.local%2Foutpost.goauthentik.io%2Fsign_out

# Use auth-disabled until authentik has an application/provider/outpost for
# each protected host, then switch to auth-authentik and restart web.
AUTH_GATEWAY_MODE=auth-disabled

# API-side enforcement trusts the gateway-auth headers or an internal bearer
# token. Keep disabled until the gateway is enforcing browser sessions.
AUTH_API_REQUIRED=false
AUTH_SERVICE_TOKEN=
AUTH_WRITE_ROLES=admin,operator
AUTH_OIDC_JWKS_URL=
AUTH_OIDC_ISSUER=
AUTH_OIDC_AUDIENCE=

# Filesystem-backed ADR authoring is local-only and bypasses Nginx.
ADR_AUTHORING_ENABLED=true
ADR_DIRECTORY=/app/docs/adr
DOCS_ORIGIN=https://docs.crazykok.local
API_DOCS_ORIGIN=https://api-docs.crazykok.local

# Comma-separated browser origins allowed to call the API directly.
CORS_ALLOWED_ORIGINS=https://crazykok.local,https://app.crazykok.local,https://api-docs.crazykok.local,https://auth.crazykok.local,https://idp.crazykok.local

API_PORT=8000

# Project-agnostic network created by the shared sites/local-gateway stack.
SITES_GATEWAY_NETWORK=sites-gateway

# Hypermedia URLs derive from trusted local proxy headers. Set a complete
# canonical API root such as https://api.example.com/v1 when deployment
# topology does not preserve forwarded host, scheme, and prefix information.
TRUST_PROXY_HEADERS=true
PUBLIC_API_BASE_URL=

# The local SQLite database is stored in the api-data Docker volume.
DATABASE_URL=sqlite:////data/app.db

# Origin for straight-line distance shown in the planning workspace.
PLANNING_HOME_LATITUDE=52.6627
PLANNING_HOME_LONGITUDE=6.8847

# Venue document and photo storage. Keep this on the same backed-up data volume.
ATTACHMENT_ROOT=/data/attachments
MAX_ATTACHMENT_BYTES=20971520
